{
  "expo": {
    "name": "FieldLog",
    "slug": "fieldlog",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "fieldlog",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#0D0F12",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.byldgo.fieldlog"
    },
    "android": {
      "package": "com.byldgo.fieldlog",
      "adaptiveIcon": {
        "backgroundColor": "#0D0F12"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-asset",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow FieldLog to access your photos so you can attach jobsite photos and your company logo."
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "Allow FieldLog to use the microphone so you can record voice daily logs."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "supabaseUrl": "https://vadvkduyalmfshvbtdxd.supabase.co",
      "supabaseAnonKey": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InZhZHZrZHV5YWxtZnNodmJ0ZHhkIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODIzNTM2NTYsImV4cCI6MjA5NzkyOTY1Nn0.60thvaU0VF6O493xyszUkdF3FKYmv6qKc5VxfwxHqoY"
    }
  }
}
